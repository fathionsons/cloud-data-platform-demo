mini_cloud_data_platform:
  target: duckdb
  outputs:
    duckdb:
      type: duckdb
      path: data/warehouse.duckdb
      threads: 4
      schema: analytics

    # Optional target for local postgres development.
    # Requires: pip install dbt-postgres==1.8.2
    postgres:
      type: postgres
      host: "{{ env_var('PGHOST', 'localhost') }}"
      user: "{{ env_var('PGUSER', 'analytics') }}"
      password: "{{ env_var('PGPASSWORD', 'analytics') }}"
      port: "{{ env_var('PGPORT', '5432') | int }}"
      dbname: "{{ env_var('PGDATABASE', 'analytics') }}"
      schema: analytics
      threads: 4
